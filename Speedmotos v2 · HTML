      position: fixed; bottom: 96px; left: 50%; transform: translateX(-50%) translateY(16px);
      background: var(--red); color: #fff; font-family: var(--font-display); font-weight: 700;
      padding: 12px 26px; border-radius: 100px; z-index: 5000;
      opacity: 0; transition: all .3s ease; pointer-events: none; white-space: nowrap;
    }
