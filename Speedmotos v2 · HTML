    <a id="modalBtn" href="#" target="_blank" class="btn btn-wpp" style="width:100%">💬 Comprar via WhatsApp</a>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
  /* Dados de produtos */
  const produtos = [
    {id:1,cat:'capacetes',e:'🪖',n:'Capacete Fechado Sport',d:'Viseira anti-risco, concha em ABS e forro lavável. Homologado pelo INMETRO.',p:'R$ 189,90',t:'INMETRO'},
    {id:2,cat:'capacetes',e:'🪖',n:'Capacete Aberto Classic',d:'Viseira solar interna, acabamento premium e encaixe anatômico. Ótimo custo-benefício.',p:'R$ 149,90',t:'Oferta'},
    {id:3,cat:'capacetes',e:'🪖',n:'Capacete Infantil',d:'Design divertido, forro macio e fivela de segurança. Ideal para crianças.',p:'R$ 89,90',t:'Infantil'},
    {id:4,cat:'pecas',e:'⚙️',n:'Filtro de Óleo Honda CG',d:'Filtro original compatível com Honda CG 125/150/160 Fan e Titan. Instalação inclusa.',p:'R$ 29,90',t:'Original'},
    {id:5,cat:'pecas',e:'🔋',n:'Bateria Moto 5Ah',d:'Bateria selada 12V 5Ah para Honda, Yamaha, Suzuki e outras. Garantia de 6 meses.',p:'R$ 129,90',t:'Garantia'},
    {id:6,cat:'pecas',e:'🔦',n:'Kit Pastilha de Freio',d:'Pastilha dianteira e traseira. Alta durabilidade e ótima resposta de frenagem.',p:'R$ 45,90',t:'Kit'},
    {id:7,cat:'pecas',e:'⛓️',n:'Kit Relação Completo',d:'Corrente, pinhão e coroa para Honda CG 150/160. Aço temperado premium.',p:'R$ 189,90',t:'Completo'},
    {id:8,cat:'acessorios',e:'🧤',n:'Luva Motociclista Gel',d:'Palmilha em gel, proteção nos nós dos dedos e fecho ajustável. Conforto em viagens longas.',p:'R$ 59,90',t:'Conforto'},
    {id:9,cat:'acessorios',e:'🔆',n:'Pisca LED Universal',d:'Par de piscas LED alta luminosidade. Universal, fácil instalação. 12V.',p:'R$ 39,90',t:'LED'},
    {id:10,cat:'acessorios',e:'🧴',n:'Kit Limpeza Moto',d:'Shampoo especial, silicone, pano microfibra e escova. Deixe sua moto impecável.',p:'R$ 49,90',t:'Kit'},
    {id:11,cat:'acessorios',e:'📦',n:'Baú Traseiro 28L',d:'Baú rígido 28L com chave, base universal e fecho duplo. Perfeito para o dia a dia.',p:'R$ 129,90',t:'Popular'},
  ];

  function wppProd(p){
    return 'https://wa.me/5518996044850?text='+encodeURIComponent('Olá! Vim pelo site e tenho interesse em: *'+p.n+'* ('+p.p+'). Poderia me passar mais informações?');
  }

  function renderProducts(cat='todos'){
    const list = cat==='todos' ? produtos : produtos.filter(x=>x.cat===cat);
    document.getElementById('productsGrid').innerHTML = list.map(p=>`
      <div class="prod-card">
        <div class="prod-img">${p.e}<span class="prod-tag">${p.t}</span></div>
        <div class="prod-info">
          <h4>${p.n}</h4>
          <p class="prod-desc">${p.d.substring(0,72)}...</p>
          <div class="prod-price">${p.p} <small>à vista</small></div>
          <div class="prod-btns">
            <button class="btn btn-outline" onclick="openModal(${p.id})">Ver detalhes</button>
            <a href="${wppProd(p)}" target="_blank" class="btn btn-wpp">💬 Comprar</a>
          </div>
        </div>
      </div>`).join('');
  }

  function filterProducts(cat,el){
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    el.classList.add('active');
    renderProducts(cat);
  }

  function openModal(id){
    const p=produtos.find(x=>x.id===id);
    document.getElementById('modalTitle').textContent=p.n;
    document.getElementById('modalIcon').textContent=p.e;
    document.getElementById('modalDesc').textContent=p.d;
    document.getElementById('modalPrice').textContent=p.p;
    document.getElementById('modalBtn').href=wppProd(p);
    document.getElementById('modalOverlay').classList.add('active');
    document.body.style.overflow='hidden';
  }
  function closeModal(e){ if(e.target.id==='modalOverlay') closeModalDirect(); }
  function closeModalDirect(){
    document.getElementById('modalOverlay').classList.remove('active');
    document.body.style.overflow='';
  }

  function enviarAgendamento(){
    const nome=document.getElementById('nome').value.trim();
    const tel=document.getElementById('telefone').value.trim();
    const moto=document.getElementById('moto').value.trim();
    const svc=document.getElementById('servico').value;
    const data=document.getElementById('data').value;
    const hor=document.getElementById('horario').value;
    const obs=document.getElementById('obs').value.trim();
    if(!nome||!tel||!svc){ showToast('⚠️ Preencha Nome, WhatsApp e Serviço!'); return; }
    let df='';
    if(data){ const[y,m,d]=data.split('-'); df=d+'/'+m+'/'+y; }
    const msg=[
      '📅 *AGENDAMENTO — SPEED MOTOS*','',
      '👤 *Nome:* '+nome,'📱 *WhatsApp:* '+tel,
      moto?'🏍️ *Moto:* '+moto:'',
      '🔧 *Serviço:* '+svc,
      df?'📆 *Data:* '+df:'',
      hor?'⏰ *Horário:* '+hor:'',
      obs?'📝 *Obs:* '+obs:'','',
      '_Enviado pelo site_'
    ].filter(Boolean).join('\n');
    window.open('https://wa.me/5518996044850?text='+encodeURIComponent(msg),'_blank');
    showToast('✅ Redirecionando para o WhatsApp!');
  }

  function showToast(msg){
    const t=document.getElementById('toast');
    t.textContent=msg; t.classList.add('show');
    setTimeout(()=>t.classList.remove('show'),3000);
  }
  function toggleMenu(){
    document.getElementById('hamburger').classList.toggle('active');
    document.getElementById('mobileMenu').classList.toggle('active');
  }
  function closeMenu(){
    document.getElementById('hamburger').classList.remove('active');
    document.getElementById('mobileMenu').classList.remove('active');
  }

  (function(){
    document.getElementById('data').min=new Date().toISOString().split('T')[0];
    renderProducts();
  })();

  document.getElementById('telefone').addEventListener('input',function(){
    let v=this.value.replace(/\D/g,'');
    v=v.length<=10?v.replace(/^(\d{2})(\d{4})(\d{0,4})/,'($1) $2-$3'):v.replace(/^(\d{2})(\d{5})(\d{0,4})/,'($1) $2-$3');
    this.value=v;
  });

  document.querySelectorAll('a[href^="#"]').forEach(a=>{
    a.addEventListener('click',function(e){
      const t=document.querySelector(this.getAttribute('href'));
      if(!t) return; e.preventDefault();
      window.scrollTo({top:t.offsetTop-78,behavior:'smooth'});
    });
  });
</script>
</body>
