  <style>
    /* ===================================================
       VARIÁVEIS — paleta Speed Motos (vermelho + chumbo)
    =================================================== */
    :root {
      --bg-deep:      #0a0a0a;
      --bg-card:      #111111;
      --bg-section:   #141414;
      --red:          #E8520A;      /* vermelho-laranja do logo */
      --red-dark:     #c44207;
      --red-glow:     rgba(232,82,10,.18);
      --red-border:   rgba(232,82,10,.25);
      --text-white:   #F2F2F2;
      --text-muted:   #888888;
      --border:       rgba(255,255,255,.07);
      --radius:       10px;
      --font-display: 'Barlow Condensed', sans-serif;
      --font-body:    'Barlow', sans-serif;
      --whatsapp:     #25D366;
      --t:            .28s cubic-bezier(.4,0,.2,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg-deep);
      color: var(--text-white);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    button, .btn { cursor: pointer; font-family: var(--font-body); border: none; }

    /* ===================================================  UTILITÁRIOS  */
    .container { max-width: 1180px; margin: 0 auto; padding: 0 20px; }
    .section    { padding: 80px 0; }
    .section-alt { background: var(--bg-section); }

    .section-label {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-display); font-size: .8rem; font-weight: 700;
      letter-spacing: .14em; text-transform: uppercase;
      color: var(--red); margin-bottom: 14px;
    }
    .section-label::before {
      content: ''; display: block; width: 20px; height: 2px; background: var(--red);
    }
    .section-title {
      font-family: var(--font-display); font-size: clamp(1.9rem, 5vw, 2.8rem);
      font-weight: 900; line-height: 1.08; margin-bottom: 8px; color: var(--text-white);
    }
    .section-title em { font-style: normal; color: var(--red); }
    .section-sub { color: var(--text-muted); font-size: .95rem; margin-bottom: 44px; }

    /* BOTÕES */
    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      gap: 8px; padding: 13px 26px;
      border-radius: 6px; font-family: var(--font-display);
      font-weight: 700; font-size: 1rem; letter-spacing: .04em;
      transition: var(--t); white-space: nowrap;
    }
    .btn-red    { background: var(--red); color: #fff; }
    .btn-red:hover { background: var(--red-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(232,82,10,.35); }
    .btn-outline { background: transparent; border: 2px solid var(--red); color: var(--red); }
    .btn-outline:hover { background: var(--red-glow); transform: translateY(-2px); }
    .btn-wpp { background: var(--whatsapp); color: #fff; }
    .btn-wpp:hover { background: #1cb554; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(37,211,102,.3); }

    /* ===================================================  NAVBAR  */
    .navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      padding: 14px 0;
      background: rgba(10,10,10,.95); backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
    }
    .navbar .container { display: flex; align-items: center; justify-content: space-between; }

    /* Logo no navbar — usa a imagem real */
    .navbar-logo img {
      height: 46px; width: auto;
      filter: drop-shadow(0 0 6px rgba(232,82,10,.5));
    }

    .nav-links { display: flex; align-items: center; gap: 28px; list-style: none; }
    .nav-links a {
      color: var(--text-muted); font-size: .88rem; font-weight: 600;
      letter-spacing: .05em; text-transform: uppercase; transition: color var(--t);
    }
    .nav-links a:hover { color: var(--red); }

    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
    .hamburger span { display: block; width: 24px; height: 2px; background: var(--text-white); border-radius: 2px; transition: var(--t); }
    .hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.active span:nth-child(2) { opacity: 0; }
    .hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ===================================================  HERO  */
    .hero {
      min-height: 100vh; display: flex; align-items: center;
      position: relative; overflow: hidden; padding-top: 80px;
    }
    /* Textura de fundo sutil */
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 70% 70% at 65% 50%, rgba(232,82,10,.09) 0%, transparent 70%),
        radial-gradient(ellipse 40% 60% at 10% 80%, rgba(232,82,10,.05) 0%, transparent 60%);
      pointer-events: none;
    }
    /* Grade sutil */
    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size: 50px 50px;
      mask-image: radial-gradient(ellipse 90% 90% at 65% 50%, black 0%, transparent 100%);
      pointer-events: none;
    }
    /* Linha decorativa vermelha lateral */
    .hero-line-deco {
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 3px; background: linear-gradient(to bottom, transparent, var(--red), transparent);
      pointer-events: none;
    }
    .hero .container {
      position: relative; z-index: 1;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 40px; align-items: center;
    }
    .hero-label {
      display: flex; align-items: center; gap: 10px; margin-bottom: 18px;
    }
    .hero-label-line { width: 28px; height: 2px; background: var(--red); }
    .hero-label-text {
      font-family: var(--font-display); font-size: .78rem; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase; color: var(--red);
    }
    .hero-title {
      font-family: var(--font-display); font-size: clamp(2.4rem, 6.5vw, 4.2rem);
      font-weight: 900; line-height: 1.05; margin-bottom: 18px;
    }
    .hero-title em { font-style: normal; color: var(--red); }
    .hero-sub { color: var(--text-muted); font-size: 1.05rem; max-width: 440px; margin-bottom: 32px; }
    .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 44px; }
    .hero-stats { display: flex; gap: 36px; flex-wrap: wrap; }
    .stat { display: flex; flex-direction: column; }
    .stat-num {
      font-family: var(--font-display); font-size: 2rem; font-weight: 900;
      color: var(--red); line-height: 1;
    }
    .stat-lbl { font-size: .78rem; color: var(--text-muted); margin-top: 2px; }

    /* Visual direita do hero — logo grande + anel */
    .hero-visual {
      display: flex; justify-content: center; align-items: center;
      position: relative;
    }
    .hero-logo-wrap {
      position: relative; z-index: 2;
      width: clamp(240px, 38vw, 380px);
      height: clamp(240px, 38vw, 380px);
      display: flex; align-items: center; justify-content: center;
    }
    /* Anel giratório externo */
    .hero-ring {
      position: absolute; inset: 0; border-radius: 50%;
      border: 1px solid var(--red-border);
      animation: spin-slow 22s linear infinite;
    }
    .hero-ring::after {
      content: ''; position: absolute; top: -5px; left: 50%;
      transform: translateX(-50%);
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--red);
      box-shadow: 0 0 14px var(--red), 0 0 30px rgba(232,82,10,.5);
    }
    .hero-ring-inner {
      position: absolute; inset: 20px; border-radius: 50%;
      border: 1px dashed rgba(232,82,10,.15);
      animation: spin-slow 14s linear infinite reverse;
    }
    @keyframes spin-slow { to { transform: rotate(360deg); } }

    /* Logo real flutuando */
    .hero-logo-img {
      width: 78%; height: auto;
      border-radius: 50%;
      animation: float 3.5s ease-in-out infinite;
      filter: drop-shadow(0 0 30px rgba(232,82,10,.5)) drop-shadow(0 0 60px rgba(232,82,10,.2));
    }
    @keyframes float {
      0%,100% { transform: translateY(0px); }
      50%      { transform: translateY(-14px); }
    }

    /* ===================================================  HIGHLIGHTS  */
    .highlights { padding: 0; margin-top: -28px; position: relative; z-index: 10; }
    .highlights-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
    .hl-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 24px 20px;
      display: flex; align-items: center; gap: 14px;
      transition: var(--t); cursor: pointer;
    }
    .hl-card:hover {
      border-color: var(--red);
      box-shadow: 0 0 20px var(--red-glow); transform: translateY(-3px);
    }
    .hl-icon {
      font-size: 1.8rem; flex-shrink: 0; width: 48px; height: 48px;
      background: var(--red-glow); border: 1px solid var(--red-border);
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
    }
    .hl-text h3 { font-family: var(--font-display); font-weight: 700; font-size: .95rem; }
    .hl-text p  { font-size: .8rem; color: var(--text-muted); }

    /* ===================================================  SERVIÇOS  */
    .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px,1fr)); gap: 20px; }
    .svc-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 28px 24px;
      position: relative; overflow: hidden; transition: var(--t);
    }
    /* Barra vermelha lateral animada */
    .svc-card::before {
      content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%;
      background: var(--red); transform: scaleY(0); transform-origin: bottom; transition: transform var(--t);
    }
    .svc-card:hover { border-color: var(--red-border); transform: translateY(-4px); }
    .svc-card:hover::before { transform: scaleY(1); }
    .svc-icon { font-size: 2.2rem; margin-bottom: 14px; }
    .svc-card h3 { font-family: var(--font-display); font-size: 1.2rem; font-weight: 800; margin-bottom: 6px; }
    .svc-card p  { color: var(--text-muted); font-size: .88rem; margin-bottom: 20px; }
    .svc-tag { font-size: .75rem; color: var(--red); font-weight: 700; letter-spacing: .06em; margin-bottom: 18px; }

    /* ===================================================  LOJA  */
    .store-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; }
    .tab-btn {
      padding: 9px 18px; border-radius: 100px;
      border: 1px solid var(--border); background: transparent;
      color: var(--text-muted); font-family: var(--font-display);
      font-weight: 700; font-size: .85rem; cursor: pointer; transition: var(--t);
    }
    .tab-btn.active, .tab-btn:hover {
      background: var(--red-glow); border-color: var(--red); color: var(--red);
    }
    .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px,1fr)); gap: 18px; }
    .prod-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); overflow: hidden; transition: var(--t);
    }
    .prod-card:hover { border-color: var(--red-border); transform: translateY(-4px); }
    .prod-img {
      width: 100%; height: 170px; background: var(--bg-section);
      display: flex; align-items: center; justify-content: center; font-size: 3.6rem;
      position: relative;
    }
    .prod-tag {
      position: absolute; top: 10px; left: 10px;
      background: var(--red); color: #fff;
      font-family: var(--font-display); font-size: .68rem; font-weight: 700;
      padding: 3px 9px; border-radius: 100px; letter-spacing: .04em;
    }
    .prod-info { padding: 18px; }
    .prod-info h4 { font-family: var(--font-display); font-weight: 800; font-size: .95rem; margin-bottom: 4px; }
    .prod-desc { font-size: .8rem; color: var(--text-muted); margin-bottom: 14px; }
    .prod-price {
      font-family: var(--font-display); font-weight: 900;
      font-size: 1.3rem; color: var(--red); margin-bottom: 14px;
    }
    .prod-price small { font-size: .68rem; color: var(--text-muted); font-weight: 400; }
    .prod-btns { display: flex; gap: 8px; }
    .prod-btns .btn { flex: 1; padding: 9px 10px; font-size: .82rem; }

    /* ===================================================  AGENDAMENTO  */
    .sched-wrap {
      display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start;
    }
    .sched-info p { color: var(--text-muted); margin-bottom: 22px; }
    .sched-points { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .sched-points li {
      display: flex; align-items: center; gap: 12px;
      font-size: .9rem; color: var(--text-muted);
    }
    .sched-points li::before {
      content: '✓'; min-width: 22px; height: 22px;
      background: var(--red-glow); border: 1px solid var(--red);
      border-radius: 50%; color: var(--red); font-size: .72rem; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
    }
    .sched-form {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 32px;
    }
    .form-group { margin-bottom: 18px; }
    .form-group label {
      display: block; font-size: .78rem; font-weight: 700;
      color: var(--text-muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 7px;
    }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; background: var(--bg-section); border: 1px solid var(--border);
      border-radius: 6px; padding: 11px 14px; color: var(--text-white);
      font-family: var(--font-body); font-size: .92rem;
      transition: var(--t); outline: none;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      border-color: var(--red); box-shadow: 0 0 0 3px var(--red-glow);
    }
    .form-group select option { background: var(--bg-card); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

    /* ===================================================  SOBRE  */
    .about-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .about-visual { position: relative; }
    .about-placeholder {
      width: 100%; aspect-ratio: 4/3;
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); display: flex; align-items: center; justify-content: center;
      font-size: 4.5rem; position: relative; overflow: hidden;
    }
    .about-placeholder::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(232,82,10,.08) 0%, transparent 60%);
    }
    .about-badge {
      position: absolute; bottom: -16px; right: -16px;
      background: var(--red); color: #fff;
      border-radius: var(--radius); padding: 18px 22px; text-align: center;
    }
    .about-badge strong {
      display: block; font-family: var(--font-display);
      font-size: 2rem; font-weight: 900; line-height: 1;
    }
    .about-badge span { font-size: .78rem; font-weight: 700; }
    .about-content p { color: var(--text-muted); margin-bottom: 14px; line-height: 1.8; }
    .diffs { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 24px; }
    .diff {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 8px; padding: 14px;
    }
    .diff-icon { font-size: 1.3rem; margin-bottom: 7px; }
    .diff h4 { font-family: var(--font-display); font-size: .9rem; font-weight: 800; margin-bottom: 3px; }
    .diff p  { font-size: .78rem; color: var(--text-muted); }

    /* ===================================================  CONTATO  */
    .contact-wrap { display: grid; grid-template-columns: 1fr 1.2fr; gap: 44px; align-items: start; }
    .ct-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 22px; margin-bottom: 14px;
      display: flex; gap: 14px; align-items: flex-start; transition: var(--t);
    }
    .ct-card:hover { border-color: var(--red-border); }
    .ct-icon {
      font-size: 1.3rem; flex-shrink: 0; width: 44px; height: 44px;
      background: var(--red-glow); border: 1px solid var(--red-border);
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
    }
    .ct-card h4 { font-family: var(--font-display); font-weight: 700; font-size: .9rem; margin-bottom: 3px; }
    .ct-card p  { color: var(--text-muted); font-size: .88rem; }
    .ct-card a  { color: var(--red); font-weight: 700; }
    .map-box {
      width: 100%; height: 300px; background: var(--bg-card);
      border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;
    }
    .map-box iframe { width: 100%; height: 100%; border: 0; }
    .horarios { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-top: 14px; }
    .hr-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 13px 18px; border-bottom: 1px solid var(--border); font-size: .88rem;
    }
    .hr-row:last-child { border-bottom: none; }
    .hr-row .open  { color: var(--red); font-weight: 700; }
    .hr-row .closed-lbl { color: var(--text-muted); }

    /* ===================================================  INSTAGRAM  */
    .insta-section {
      background: var(--bg-section); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      padding: 56px 0; text-align: center;
    }
    .btn-insta {
      background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
      color: #fff;
    }
    .btn-insta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(220,39,67,.3); }

    /* ===================================================  FOOTER  */
    .footer { background: #070707; padding: 44px 0 20px; border-top: 1px solid var(--border); }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 36px; margin-bottom: 36px; }
    .footer-logo img { height: 54px; width: auto; margin-bottom: 12px; }
    .footer-brand p { color: var(--text-muted); font-size: .88rem; line-height: 1.7; }
    .footer-col h4 {
      font-family: var(--font-display); font-weight: 700; font-size: .8rem;
      letter-spacing: .1em; text-transform: uppercase; color: var(--red); margin-bottom: 14px;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
    .footer-col a { color: var(--text-muted); font-size: .88rem; transition: color var(--t); }
    .footer-col a:hover { color: var(--red); }
    .footer-bottom {
      border-top: 1px solid var(--border); padding-top: 20px;
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 10px; font-size: .78rem; color: var(--text-muted);
    }
    .footer-bottom span b { color: var(--red); }

    /* ===================================================  WPP FLOAT  */
    .wpp-float {
      position: fixed; bottom: 26px; right: 26px;
      width: 58px; height: 58px; background: var(--whatsapp);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem; z-index: 9999; text-decoration: none;
      box-shadow: 0 4px 20px rgba(37,211,102,.45);
      animation: pulse-wpp 2.2s ease-in-out infinite;
      transition: var(--t);
    }
    .wpp-float:hover { transform: scale(1.12); box-shadow: 0 8px 32px rgba(37,211,102,.6); }
    @keyframes pulse-wpp {
      0%,100% { box-shadow: 0 4px 20px rgba(37,211,102,.45); }
      50%      { box-shadow: 0 4px 32px rgba(37,211,102,.9), 0 0 0 10px rgba(37,211,102,.1); }
    }
    .wpp-float::before {
      content: 'Fale Conosco'; position: absolute; right: 68px;
      background: #fff; color: #000; padding: 6px 12px; border-radius: 6px;
      font-family: var(--font-body); font-size: .78rem; font-weight: 700;
      white-space: nowrap; opacity: 0; transform: translateX(6px); transition: var(--t);
      pointer-events: none;
    }
    .wpp-float:hover::before { opacity: 1; transform: translateX(0); }

    /* ===================================================  MODAL  */
    .modal-overlay {
